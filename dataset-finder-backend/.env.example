# Dataset Finder Backend — required environment variables
# Copy this file to .env and fill in your values

ANTHROPIC_API_KEY=your_anthropic_api_key_here
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dataset-finder

# Optional
JWT_SECRET=dataset-finder-secret-2026
SERPER_API_KEY=your_serper_api_key_here
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
PORT=3001
FRONTEND_URL=http://localhost:5173
